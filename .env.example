# Phase 0 is intentionally shadow-only. Changing either value causes startup to fail.
SHADOW_MODE=true
LIVE_TRADING_ENABLED=false

# Local, relative paths. API credentials are not used until Phase 1.
JOURNAL_PATH=data/shadow_journal.db
LOG_PATH=logs/shadow_bot.jsonl

# Optional: path to the root CA used by your VPN, company proxy, or network
# security software. Never disable SSL verification to work around this issue.
# SSL_CERT_FILE=/Users/cheng-kaihuang/Polymarket-stock/certs/network-root-ca.pem

# Required only for `snapshot-alpaca-options`. The client always requests the
# free Indicative feed and labels it non-live-grade.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Default provider for `stream-shadow`. Finnhub is a market-data API and does
# not require a brokerage account. Keep the actual key only in local `.env`.
FINNHUB_API_KEY=
